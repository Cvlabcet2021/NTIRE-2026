# ------------------------------------------------
# Dataset With Augmentation
# ------------------------------------------------
class DehazeDataset(Dataset):
    def __init__(self, hazy, gt, patch=1184):
        self.hazy = hazy
        self.gt = gt
        self.patch = patch
        self.to_tensor = T.ToTensor()

    def __len__(self):
        return len(self.hazy)

    def augment(self, hazy, gt):
        if random.random() > 0.5:
            hazy = np.fliplr(hazy).copy()
            gt   = np.fliplr(gt).copy()
        if random.random() > 0.5:
            hazy = np.flipud(hazy).copy()
            gt   = np.flipud(gt).copy()
        if random.random() > 0.5:
            k = random.randint(1,3)
            hazy = np.rot90(hazy, k).copy()
            gt   = np.rot90(gt, k).copy()
        return hazy, gt

    def __getitem__(self, idx):
        hazy = cv2.imread(self.hazy[idx], cv2.IMREAD_COLOR)
        gt   = cv2.imread(self.gt[idx], cv2.IMREAD_COLOR)

        hazy = cv2.cvtColor(hazy, cv2.COLOR_BGR2RGB)
        gt   = cv2.cvtColor(gt, cv2.COLOR_BGR2RGB)

        h, w = hazy.shape[:2]
        ps = self.patch

        pad_bottom = max(0, ps - h)
        pad_right  = max(0, ps - w)
        if pad_bottom > 0 or pad_right > 0:
            hazy = cv2.copyMakeBorder(hazy, 0, pad_bottom, 0, pad_right, cv2.BORDER_REFLECT_101)
            gt   = cv2.copyMakeBorder(gt,   0, pad_bottom, 0, pad_right, cv2.BORDER_REFLECT_101)
            h, w = hazy.shape[:2]

        y = random.randint(0, h - ps)
        x = random.randint(0, w - ps)

        hazy = hazy[y:y+ps, x:x+ps]
        gt   = gt[y:y+ps, x:x+ps]

        hazy, gt = self.augment(hazy, gt)
        return self.to_tensor(hazy), self.to_tensor(gt)


# ------------------------------------------------
# Model (ResNet34 UNet)
# ------------------------------------------------
class UNetResNet(nn.Module):
    def __init__(self):
        super().__init__()
        try:
            base = models.resnet34(weights=models.ResNet34_Weights.IMAGENET1K_V1)
        except Exception:
            base = models.resnet34(pretrained=True)

        layers = list(base.children())
        self.enc0 = nn.Sequential(*layers[:3])
        self.pool0 = layers[3]
        self.enc1 = layers[4]
        self.enc2 = layers[5]
        self.enc3 = layers[6]
        self.enc4 = layers[7]

        self.up4 = nn.ConvTranspose2d(512,256,2,2)
        self.dec4 = nn.Sequential(nn.Conv2d(512,256,3,padding=1), nn.ReLU())

        self.up3 = nn.ConvTranspose2d(256,128,2,2)
        self.dec3 = nn.Sequential(nn.Conv2d(256,128,3,padding=1), nn.ReLU())

        self.up2 = nn.ConvTranspose2d(128,64,2,2)
        self.dec2 = nn.Sequential(nn.Conv2d(128,64,3,padding=1), nn.ReLU())

        self.up1 = nn.ConvTranspose2d(64,64,2,2)
        self.dec1 = nn.Sequential(nn.Conv2d(128,64,3,padding=1), nn.ReLU())

        self.up0 = nn.ConvTranspose2d(64,64,2,2)
        self.final = nn.Conv2d(64,3,1)

    def forward(self, x):
        e0 = self.enc0(x)
        p0 = self.pool0(e0)
        e1 = self.enc1(p0)
        e2 = self.enc2(e1)
        e3 = self.enc3(e2)
        e4 = self.enc4(e3)

        d4 = torch.cat([self.up4(e4), e3], 1); d4 = self.dec4(d4)
        d3 = torch.cat([self.up3(d4), e2], 1); d3 = self.dec3(d3)
        d2 = torch.cat([self.up2(d3), e1], 1); d2 = self.dec2(d2)
        d1 = torch.cat([self.up1(d2), e0], 1); d1 = self.dec1(d1)

        out = torch.sigmoid(self.final(self.up0(d1)))
        return out


# ------------------------------------------------
# Loss
# ------------------------------------------------
class CharbonnierLoss(nn.Module):
    def __init__(self, eps=1e-3):
        super().__init__()
        self.eps = eps
    def forward(self, x, y):
        return torch.mean(torch.sqrt((x-y)**2 + self.eps**2))

def ssim_loss(x, y):
    return torch.mean((F.avg_pool2d(x,3,1,1) - F.avg_pool2d(y,3,1,1))**2)

def psnr(pred, gt):
    mse = torch.mean((pred-gt)**2)
    return 20 * torch.log10(1.0 / torch.sqrt(mse + 1e-8))


# ------------------------------------------------
# Training Setup
# ------------------------------------------------
dataset = DehazeDataset(train_hazy, train_gt, patch=1184)

loader  = DataLoader(dataset, batch_size=2, shuffle=True, num_workers=2, pin_memory=True)

model = UNetResNet().to(device)
optimizer = optim.AdamW(model.parameters(), lr=1e-4)
scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=800)

criterion = CharbonnierLoss()
epochs = 800

use_amp = False
scaler = torch.cuda.amp.GradScaler(enabled=use_amp)


# ------------------------------------------------
# SAVE CHECKPOINT (Modified)
# ------------------------------------------------
def save_checkpoint(epoch_idx, is_final=False):
    if is_final:
        final_path_local = "checkpoints/high_psnr_model_final.pth"
        final_path_drive = f"{drive_ckpt_path}/high_psnr_model_final.pth"

        torch.save(model.state_dict(), final_path_local)
        torch.save(model.state_dict(), final_path_drive)

        print(f"✔ Final model saved locally: {final_path_local}")
        print(f"✔ Final model saved to Drive: {final_path_drive}")

    else:
        ckpt_data = {
            "epoch": epoch_idx,
            "model_state": model.state_dict(),
            "optimizer_state": optimizer.state_dict(),
            "scheduler_state": scheduler.state_dict(),
            "seed": seed,
        }

        local_path = f"checkpoints/high_psnr_epoch{epoch_idx}.pth"
        drive_path = f"{drive_ckpt_path}/high_psnr_epoch{epoch_idx}.pth"

        torch.save(ckpt_data, local_path)
        torch.save(ckpt_data, drive_path)

        print(f"✔ Checkpoint saved: {local_path}")
        print(f"✔ Checkpoint saved to Drive: {drive_path}")


# ------------------------------------------------
# Training Loop (unchanged)
# ------------------------------------------------
for ep in range(epochs):
    model.train()
    total_psnr = 0.0

    for hazy, gt in loader:
        hazy, gt = hazy.to(device), gt.to(device)
        optimizer.zero_grad(set_to_none=True)

        if use_amp:
            with torch.cuda.amp.autocast():
                pred = model(hazy)
                loss = criterion(pred, gt) + 0.1 * ssim_loss(pred, gt)
            scaler.scale(loss).backward()
            scaler.step(optimizer)
            scaler.update()
        else:
            pred = model(hazy)
            loss = criterion(pred, gt) + 0.1 * ssim_loss(pred, gt)
            loss.backward()
            optimizer.step()

        total_psnr += psnr(pred.detach(), gt).item()

    scheduler.step()
    avg_psnr = total_psnr / max(1, len(loader))
    print(f"Epoch {ep+1}/{epochs} | PSNR: {avg_psnr:.2f}")

    if (ep + 1) % 20 == 0:
        save_checkpoint(ep + 1)

save_checkpoint(epochs, is_final=True)


# ------------------------------------------------
# Sliding Window Inference
# ------------------------------------------------
@torch.no_grad()
def sliding_window_inference(model, img, window=1184, overlap=256):
    _, _, h, w = img.shape
    out = torch.zeros((1, 3, h, w), device=img.device)
    cnt = torch.zeros((1, 3, h, w), device=img.device)

    stride = window - overlap
    ys = list(range(0, max(1, h - window + 1), stride))
    xs = list(range(0, max(1, w - window + 1), stride))

    if ys[-1] != h - window: ys.append(h - window)
    if xs[-1] != w - window: xs.append(w - window)

    model.eval()
    for y in ys:
        for x in xs:
            patch = img[:, :, y:y+window, x:x+window]
            pred = model(patch).clamp(0, 1)
            out[:, :, y:y+window, x:x+window] += pred
            cnt[:, :, y:y+window, x:x+window] += 1

    return out / cnt.clamp_min(1e-6)


# ------------------------------------------------
# Inference
# ------------------------------------------------
test_folder = "/content/dataset/test/hazy"
test_images = sorted(glob(f"{test_folder}/*"))

print("Testing images:", len(test_images))

for p in tqdm(test_images):
    img = cv2.imread(p, cv2.IMREAD_COLOR)
    rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

    tens = T.ToTensor()(rgb).unsqueeze(0).to(device)
    out  = sliding_window_inference(model, tens, window=1184, overlap=256)

    out_np = out.squeeze().detach().cpu().numpy().transpose(1,2,0)
    out_np = (out_np * 255).astype(np.uint8)

    cv2.imwrite(f"results/{os.path.basename(p)}",
                cv2.cvtColor(out_np, cv2.COLOR_RGB2BGR))

print("✔ Inference Done!")
